graph TD
    Routes["Route modules\ndrafts / assistant / members / studio"]
    Deps["Auth + role deps"]
    DraftService["Draft service logic\nCRUD, snapshots, collaborators"]
    AssistantService["Assistant service\nprompting + model routing"]
    Realtime["Realtime manager\npresence + patch fan-out"]
    SQLite[("SQLite")]
    LM["LM Studio"]

    Routes --> Deps
    Routes --> DraftService
    Routes --> AssistantService
    Routes --> Realtime
    DraftService --> SQLite
    AssistantService --> SQLite
    AssistantService --> LM
