APP_NAME=DraftDeck API
API_PREFIX=/api
DATABASE_URL=sqlite:///./data/draftdeck.db
FRONTEND_ORIGIN=http://localhost:3000
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
# Replace these with model ids returned by GET /v1/models in LM Studio.
# Verified local example: qwen/qwen3-1.7b
LLM_FAST_MODEL=qwen/qwen3-1.7b
LLM_DEEP_MODEL=qwen/qwen3-1.7b
LM_STUDIO_TIMEOUT_SECONDS=60
# Set to true to use the mock assistant without LM Studio.
LLM_MOCK=false
